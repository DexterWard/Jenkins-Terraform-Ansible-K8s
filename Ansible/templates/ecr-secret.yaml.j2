apiVersion: v1
kind: Secret
metadata:
  name: ecr-secret
type: kubernetes.io/dockerconfigjson
stringData:
  .dockerconfigjson: |
    {
      "auths": {
        "{{ ecr_server }}": {
          "username": "AWS",
          "password": "{{ ecr_token }}",
          "auth": "{{ ('AWS:' ~ ecr_token) | b64encode }}"
        }
      }
    }
