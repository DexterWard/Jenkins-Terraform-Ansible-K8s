apiVersion: apps/v1
kind: Deployment
metadata:
    name: demo-app
spec:
    replicas: 2
    selector:
        matchLabels:
            app: demo-app
    template:
        metadata:
            labels:
                app: demo-app
        spec:
            containers:
            - name: demo-app
              image: "{{ ACCOUNT_ID }}.dkr.ecr.{{ REGION }}.amazonaws.com/my-project:{{ IMAGE_TAG }}"
              env:
          
              - name: DB_HOST
                valueFrom:
                    secretKeyRef:
                        name: rds-secret
                        key: db-host
        
              - name: DB_NAME
                valueFrom:
                    secretKeyRef:
                        name: rds-secret
                        key: db-name

              - name: DB_USER
                valueFrom:
                    secretKeyRef:
                        name: rds-secret
                        key: db-user

              - name: DB_PASSWORD
                valueFrom:
                    secretKeyRef:
                        name: rds-secret
                        key: db-password